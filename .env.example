# Amazon Bedrock Knowledge Base ID (from provisioning step)
KNOWLEDGE_BASE_ID=your-knowledge-base-id

# AWS region
AWS_REGION=us-east-1

# Tavily API key for web search fallback
TAVILY_API_KEY=tvly-your-api-key

# Minimum retrieval score for strands retrieve tool
MIN_SCORE=0.2

# ── Agent LLM ──────────────────────────────────────────────
# Provider: bedrock | anthropic | openai | ollama
AGENT_PROVIDER=bedrock

# Model ID (provider-specific). Leave blank to use the provider default.
#   bedrock   → us.anthropic.claude-3-7-sonnet-20250219-v1:0
#   anthropic → claude-sonnet-4-20250514
#   openai    → gpt-4o
#   ollama    → llama3
AGENT_MODEL_ID=

# ── Provider credentials (only needed for non-Bedrock providers) ──
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=              # custom endpoint (Azure, vLLM, LM Studio, etc.)
# OLLAMA_HOST=http://localhost:11434

# ── Evaluation / embeddings (always uses Bedrock) ──────────
EVAL_MODEL_ID=us.anthropic.claude-3-7-sonnet-20250219-v1:0
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# RAGAS context precision threshold (chunks below this are considered irrelevant)
RELEVANCE_THRESHOLD=0.5
